# World Intelligence Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.

# ─── Google Gemini ───────────────────────────────────────────────────────────
# Get a free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Notes ───────────────────────────────────────────────────────────────────
# GDELT, World Bank, and Yahoo Finance are public APIs that require NO key.
# The dashboard caches all external responses for 10 minutes to minimise
# request volume and stay within free-tier limits.
